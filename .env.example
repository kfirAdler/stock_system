FLASK_SECRET_KEY=replace_with_secure_random_value
OUTPUT_DIR=/data/output
DATA_PROVIDER_MODE=auto
SCAN_WORKERS=5
HISTORY_TAIL_ROWS=1200
HISTORY_FETCH_LOOKBACK_DAYS=1800
MIN_REFETCH_INTERVAL_MINUTES=30
WORKER_STALL_TIMEOUT_SECONDS=90

# Supabase Postgres integration
SAVE_TO_SUPABASE=true
SUPABASE_DB_URL=postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres?sslmode=require
